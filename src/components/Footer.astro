---
const sports = [
  { label: "Tennis Rackets", href: "/tennis" },
  { label: "Badminton Rackets", href: "/badminton" },
  { label: "Pickleball Paddles", href: "/pickleball" },
  { label: "Squash Rackets", href: "/squash" },
  { label: "Table Tennis Tables", href: "/table-tennis" },
];
const company = [
  { label: "About Us", href: "/about" },
  { label: "How We Test", href: "/methodology" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="bg-slate-900 text-slate-300 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-green-600 rounded-md flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-white tracking-tight">MySweetSpot</span>
        </div>
        <p class="text-sm leading-relaxed max-w-xs text-slate-400">
          Independent, in-depth racket reviews for Indian players. We test, compare, and break down every spec so you can pick the right gear with confidence.
        </p>
        <p class="text-xs text-slate-500 mt-4">
          MySweetSpot participates in the Amazon Associates (India) and Flipkart Affiliate programmes. We may earn a commission when you buy through our links — at no extra cost to you.
        </p>
      </div>

      <!-- Sports -->
      <div>
        <h3 class="font-[Barlow_Condensed] text-white text-lg font-semibold mb-4 tracking-wide uppercase">Sports</h3>
        <ul class="space-y-2">
          {sports.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-[Barlow_Condensed] text-white text-lg font-semibold mb-4 tracking-wide uppercase">Company</h3>
        <ul class="space-y-2">
          {company.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="border-t border-slate-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        &copy; {new Date().getFullYear()} MySweetSpot. All rights reserved.
      </p>
      <div class="flex gap-4 text-xs text-slate-500">
        <a href="/privacy" class="hover:text-slate-300 transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-slate-300 transition-colors">Terms of Use</a>
        <a href="/disclosure" class="hover:text-slate-300 transition-colors">Affiliate Disclosure</a>
      </div>
    </div>

  </div>
</footer>
