---
import RatingBadge from "./RatingBadge.astro";

interface Props {
  name: string;
  tagline: string;
  image: string;
  rating: number;
  price: string;
  buyUrl: string;
  highlights: string[];
  badge?: string;
}

const {
  name,
  tagline,
  image,
  rating,
  price,
  buyUrl,
  highlights,
  badge = "Our Top Pick",
} = Astro.props;
---

<div class="relative rounded-2xl border-2 border-green-500 bg-white overflow-hidden shadow-md">

  <!-- Top label strip -->
  <div class="bg-green-600 text-white text-xs font-semibold uppercase tracking-widest px-4 py-2 flex items-center gap-2">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    {badge}
  </div>

  <div class="p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 items-start">

      <!-- Image -->
      <div class="flex-shrink-0 w-full sm:w-44 h-44 bg-slate-100 rounded-xl overflow-hidden flex items-center justify-center">
        <img
          src={image}
          alt={`${name} racket`}
          class="w-full h-full object-contain p-4"
          loading="eager"
          width="176"
          height="176"
        />
      </div>

      <!-- Info -->
      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <h2 class="font-[Barlow_Condensed] text-3xl font-bold text-slate-900 leading-tight">{name}</h2>
            <p class="text-slate-500 mt-1 text-sm">{tagline}</p>
          </div>
          <RatingBadge score={rating} size="lg" />
        </div>

        <!-- Highlights -->
        <ul class="mt-4 space-y-1.5">
          {highlights.map(h => (
            <li class="flex items-start gap-2 text-sm text-slate-700">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {h}
            </li>
          ))}
        </ul>

        <!-- Price + CTA -->
        <div class="mt-6 flex items-center gap-4 flex-wrap">
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">{price}</span>
          <a
            href={buyUrl}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors cursor-pointer"
            aria-label={`Check price for ${name}`}
          >
            Check Price
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
          <a href={`#${name.toLowerCase().replace(/\s+/g, "-")}`} class="text-sm text-green-600 font-medium hover:underline">
            Read full review ↓
          </a>
        </div>
      </div>

    </div>
  </div>

</div>
