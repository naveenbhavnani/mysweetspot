---
import RatingBadge from "./RatingBadge.astro";
import ImageGallery from "./ImageGallery.astro";

interface RatingCategory {
  label: string;
  score: number;
}

interface Props {
  name: string;
  tagline: string;
  image: string;
  images?: string[];
  overallRating: number;
  price: string;
  buyUrl: string;
  specs: Record<string, string>;
  pros: string[];
  cons: string[];
  ratingBreakdown?: RatingCategory[];
  reviewText?: string;
  badge?: string;
}

const {
  name,
  tagline,
  image,
  images,
  overallRating,
  price,
  buyUrl,
  specs,
  pros,
  cons,
  ratingBreakdown = [],
  reviewText,
  badge,
} = Astro.props;

const anchorId = name.toLowerCase().replace(/\s+/g, "-");
const galleryImages = images && images.length > 0 ? images : [image];
const thumbnailSrc = galleryImages[0];
const hasRating = ratingBreakdown.length > 0;
---

<article id={anchorId} class="scroll-mt-24 border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white">

  <!-- Header: thumbnail | name + tagline | rating | price + CTA -->
  <div class="bg-slate-50 border-b border-slate-200 px-6 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 bg-white rounded-xl border border-slate-200 flex items-center justify-center flex-shrink-0 overflow-hidden">
        <img
          src={thumbnailSrc}
          alt={name}
          class="w-full h-full object-contain p-1"
          loading="lazy"
          width="56"
          height="56"
        />
      </div>
      <div>
        <div class="flex items-center gap-2 flex-wrap">
          <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">{name}</h2>
          {badge && (
            <span class="text-xs font-semibold text-green-700 bg-green-100 px-2 py-0.5 rounded-full">{badge}</span>
          )}
        </div>
        <p class="text-sm text-slate-500 mt-0.5">{tagline}</p>
      </div>
    </div>

    <div class="flex items-center gap-4 flex-shrink-0">
      <div class="text-right">
        <p class="text-xs text-slate-500 mb-1">Our Rating</p>
        <RatingBadge score={overallRating} size="lg" />
      </div>
      <div class="text-right">
        <p class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 tabular-nums">{price}</p>
        <a
          href={buyUrl}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white font-semibold text-xs px-4 py-2 rounded-lg transition-colors mt-1 cursor-pointer"
          aria-label={`Check price for ${name}`}
        >
          Check Price
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="p-6 space-y-6">

    <!-- Row 1: Gallery (left) + Specs (right) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">

      <!-- Gallery -->
      <ImageGallery images={galleryImages} alt={name} id={anchorId} />

      <!-- Specs -->
      <div>
        <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900 uppercase tracking-wide mb-3">Specifications</h3>
        <div class="rounded-xl border border-slate-200 overflow-hidden">
          <table class="w-full text-sm" aria-label={`Specifications for ${name}`}>
            <tbody>
              {Object.entries(specs).map(([key, val], idx) => (
                <tr class={idx % 2 === 0 ? "bg-white" : "bg-slate-50"}>
                  <th scope="row" class="text-left px-4 py-2.5 font-medium text-slate-500 w-36 border-r border-slate-100 whitespace-nowrap">
                    {key}
                  </th>
                  <td class="px-4 py-2.5 text-slate-800 font-medium">{val}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Row 2: Pros | Cons | Rating breakdown -->
    <div class={`grid grid-cols-1 gap-4 ${hasRating ? "sm:grid-cols-3" : "sm:grid-cols-2"}`}>

      <!-- Pros -->
      <div class="rounded-xl bg-green-50 border border-green-200 p-4">
        <h4 class="font-[Barlow_Condensed] font-bold text-green-800 text-base uppercase tracking-wide mb-3 flex items-center gap-1.5">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Pros
        </h4>
        <ul class="space-y-2">
          {pros.map(pro => (
            <li class="flex items-start gap-2 text-sm text-green-900">
              <span class="text-green-500 flex-shrink-0 mt-0.5" aria-hidden="true">+</span>
              {pro}
            </li>
          ))}
        </ul>
      </div>

      <!-- Cons -->
      <div class="rounded-xl bg-red-50 border border-red-200 p-4">
        <h4 class="font-[Barlow_Condensed] font-bold text-red-800 text-base uppercase tracking-wide mb-3 flex items-center gap-1.5">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
          Cons
        </h4>
        <ul class="space-y-2">
          {cons.map(con => (
            <li class="flex items-start gap-2 text-sm text-red-900">
              <span class="text-red-400 flex-shrink-0 mt-0.5" aria-hidden="true">−</span>
              {con}
            </li>
          ))}
        </ul>
      </div>

      <!-- Rating breakdown (only if provided) -->
      {hasRating && (
        <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
          <h4 class="font-[Barlow_Condensed] font-bold text-slate-800 text-base uppercase tracking-wide mb-3">
            Rating Breakdown
          </h4>
          <div class="space-y-3">
            {ratingBreakdown.map(cat => (
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="font-medium text-slate-700">{cat.label}</span>
                  <span class="font-[Barlow_Condensed] font-bold text-slate-900 tabular-nums">{cat.score.toFixed(1)}</span>
                </div>
                <div class="h-2 bg-slate-200 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-green-500 rounded-full rating-bar-fill"
                    style={`--target-width: ${(cat.score / 10) * 100}%`}
                    role="meter"
                    aria-valuenow={cat.score}
                    aria-valuemin={0}
                    aria-valuemax={10}
                    aria-label={`${cat.label}: ${cat.score} out of 10`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Row 3: Verdict (full width, only if provided) -->
    {reviewText && (
      <div class="border-t border-slate-100 pt-5">
        <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900 uppercase tracking-wide mb-2">Our Verdict</h3>
        <p class="text-sm text-slate-600 leading-relaxed">{reviewText}</p>
      </div>
    )}

    <!-- Browse on Amazon CTA -->
    <div class="flex justify-center pt-2">
      <a
        href={buyUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm px-6 py-3 rounded-xl transition-colors cursor-pointer"
        aria-label={`Browse ${name} on Amazon`}
      >
        Browse on Amazon
      </a>
    </div>

  </div>

</article>
