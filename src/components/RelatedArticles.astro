---
import RatingBadge from "./RatingBadge.astro";
import { getRelatedReviews } from "../data/reviewRegistry";
import type { ReviewSummary } from "../data/reviewRegistry";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const { sameSport, otherSports } = getRelatedReviews(currentSlug);

const sportLabels: Record<string, string> = {
  tennis: "Tennis",
  badminton: "Badminton",
  pickleball: "Pickleball",
  squash: "Squash",
  "table-tennis": "Table Tennis",
};

const sportTagColors: Record<string, string> = {
  tennis: "bg-lime-100 text-lime-700",
  badminton: "bg-cyan-100 text-cyan-700",
  pickleball: "bg-orange-100 text-orange-700",
  squash: "bg-blue-100 text-blue-700",
  "table-tennis": "bg-violet-100 text-violet-700",
};

const currentSport = sameSport.length > 0 ? sameSport[0].sport : null;

const hasContent = sameSport.length > 0 || otherSports.length > 0;
---

{hasContent && (
  <section id="related-articles" class="scroll-mt-24 border-t border-slate-200 pt-10">
    {sameSport.length > 0 && currentSport && (
      <div class="mb-10">
        <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">
          More {sportLabels[currentSport]} Reviews
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {sameSport.map((r: ReviewSummary) => (
            <a
              href={`/reviews/${r.slug}`}
              class="group bg-white border border-slate-200 rounded-2xl p-5 transition-all hover:shadow-md hover:border-slate-300"
            >
              <div class="flex items-center gap-2 mb-3">
                {r.level && (
                  <span class="text-xs font-medium text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full">
                    {r.level}
                  </span>
                )}
              </div>
              <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900 group-hover:text-green-600 transition-colors leading-snug mb-3">
                {r.title}
              </h3>
              <div class="flex items-center justify-between mb-3">
                <div>
                  <p class="text-xs text-slate-400 mb-0.5">Top Pick</p>
                  <p class="text-sm font-medium text-slate-700">{r.topPickName}</p>
                  <p class="text-xs text-slate-500">{r.topPickPrice}</p>
                </div>
                <RatingBadge score={r.topPickRating} size="sm" />
              </div>
              <div class="border-t border-slate-100 pt-3">
                <span class="text-sm text-green-600 font-semibold group-hover:underline">
                  Read review &rarr;
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {otherSports.length > 0 && (
      <div>
        <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">
          Explore Other Sports
        </h2>
        <div class="flex flex-col sm:flex-row gap-3">
          {otherSports.map((r: ReviewSummary) => (
            <a
              href={`/reviews/${r.slug}`}
              class="group flex items-center gap-3 bg-white border border-slate-200 rounded-xl px-4 py-3 transition-all hover:shadow-md hover:border-slate-300 sm:flex-1"
            >
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap ${sportTagColors[r.sport]}`}>
                {sportLabels[r.sport]}
              </span>
              <span class="text-sm font-medium text-slate-700 group-hover:text-green-600 transition-colors leading-snug flex-1">
                {r.title}
              </span>
              <span class="text-green-600 flex-shrink-0" aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
)}
