---
import RatingBadge from "./RatingBadge.astro";

export interface Product {
  name: string;
  rating: number;
  price: string;
  buyUrl: string;
  badge?: string;
  specs: {
    weight?: string;
    balance?: string;
    headSize?: string;
    stringPattern?: string;
    material?: string;
    flexibility?: string;
    level?: string;
  };
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
  <table class="w-full text-sm min-w-[640px]" role="table" aria-label="Product comparison table">
    <thead class="bg-slate-50 border-b-2 border-slate-200">
      <tr>
        <th scope="col" class="text-left px-4 py-3 font-semibold text-slate-700 w-48">Racket</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700">Rating</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700">Price</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700">Weight</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700">Balance</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700">Head Size</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700">Level</th>
        <th scope="col" class="text-center px-3 py-3 font-semibold text-slate-700 sr-only">Buy</th>
      </tr>
    </thead>
    <tbody>
      {products.map((p, i) => (
        <tr class={`border-b border-slate-100 hover:bg-slate-50 transition-colors ${i === 0 ? "bg-green-50/50" : ""}`}>
          <td class="px-4 py-3">
            <div class="flex flex-col gap-0.5">
              <a
                href={`#${p.name.toLowerCase().replace(/\s+/g, "-")}`}
                class="font-semibold text-slate-900 hover:text-green-600 transition-colors leading-tight"
              >
                {p.name}
              </a>
              {p.badge && (
                <span class="inline-block text-xs font-medium text-green-700 bg-green-100 rounded px-1.5 py-0.5 w-fit mt-0.5">
                  {p.badge}
                </span>
              )}
            </div>
          </td>
          <td class="px-3 py-3 text-center">
            <div class="flex justify-center">
              <RatingBadge score={p.rating} size="sm" />
            </div>
          </td>
          <td class="px-3 py-3 text-center font-[Barlow_Condensed] text-base font-semibold text-slate-900 tabular-nums">
            {p.price}
          </td>
          <td class="px-3 py-3 text-center text-slate-600">{p.specs.weight ?? "—"}</td>
          <td class="px-3 py-3 text-center text-slate-600">{p.specs.balance ?? "—"}</td>
          <td class="px-3 py-3 text-center text-slate-600">{p.specs.headSize ?? "—"}</td>
          <td class="px-3 py-3 text-center text-slate-600">{p.specs.level ?? "—"}</td>
          <td class="px-3 py-3 text-center">
            <a
              href={p.buyUrl}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="inline-flex items-center gap-1 text-xs font-semibold text-green-700 bg-green-100 hover:bg-green-200 px-3 py-1.5 rounded-md transition-colors whitespace-nowrap cursor-pointer"
              aria-label={`Buy ${p.name}`}
            >
              Buy Now
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
