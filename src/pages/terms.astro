---
import BaseLayout from "../layouts/BaseLayout.astro";
const today = new Date().toLocaleDateString("en-IN", { year: "numeric", month: "long", day: "numeric" });
---
<BaseLayout title="Terms of Use" description="MySweetSpot terms of use.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <nav class="text-xs text-slate-500 mb-6" aria-label="Breadcrumb"><a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Terms of Use</span></nav>
    <h1 class="font-[Barlow_Condensed] text-4xl font-bold text-slate-900 mb-2">Terms of Use</h1>
    <p class="text-xs text-slate-400 mb-8">Last updated: {today}</p>
    <div class="space-y-5 text-sm text-slate-600 leading-relaxed">
      <p>By accessing mysweetspot.in, you agree to these terms. If you do not agree, please do not use this site.</p>
      <p><strong class="text-slate-800">Content accuracy:</strong> We strive to keep pricing, specifications, and availability information accurate. However, product details change frequently. Always verify current pricing and availability directly with the retailer before purchasing.</p>
      <p><strong class="text-slate-800">Intellectual property:</strong> All written content, ratings, and original images on this site are owned by MySweetSpot. Product images sourced from Amazon are the property of their respective rights holders and are used for editorial purposes.</p>
      <p><strong class="text-slate-800">Limitation of liability:</strong> MySweetSpot is not liable for any purchasing decisions made based on content on this site. Reviews represent our honest opinions but individual experiences may vary.</p>
      <p><strong class="text-slate-800">Governing law:</strong> These terms are governed by the laws of India.</p>
    </div>
  </div>
</BaseLayout>
