---
import BaseLayout from "../layouts/BaseLayout.astro";
import { aboutPageSchema, breadcrumbSchema } from "../utils/schema";

const jsonLd = { "@graph": [
  aboutPageSchema({ url: "/about", name: "About MySweetSpot", description: "MySweetSpot is India's independent racket sport review site — tennis, badminton, pickleball, and squash." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "About", url: "/about" }]),
] } as Record<string, unknown>;
---
<BaseLayout title="About MySweetSpot" description="MySweetSpot is India's independent racket sport review site — tennis, badminton, pickleball, and squash." jsonLd={jsonLd}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <nav class="text-xs text-slate-500 mb-6" aria-label="Breadcrumb"><a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">About</span></nav>
    <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900 mb-6">About MySweetSpot</h1>
    <div class="space-y-5 text-sm text-slate-600 leading-relaxed">
      <p>MySweetSpot started because we couldn't find a single Indian review site that took racket buying seriously. Most articles were rehashed spec sheets or thinly disguised ads. We wanted reviews written for Indian conditions — Indian pricing, Indian availability, and the kind of clubs and courts most of us actually play on.</p>
      <p>We cover tennis, badminton, pickleball, and squash. We test every racket we review on court, and we publish our rating criteria openly so you can judge whether our priorities match yours.</p>
      <p>We're based in India and we buy the products we review. We participate in affiliate programmes (Amazon.in, Flipkart) — that's how we keep the lights on — but affiliate income never influences a rating or recommendation.</p>
      <p>Questions? Suggestions for rackets we should review? <a href="/contact" class="text-green-600 hover:underline">Get in touch.</a></p>
    </div>
  </div>
</BaseLayout>
