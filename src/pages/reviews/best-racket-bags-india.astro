---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { webPageSchema, breadcrumbSchema, faqSchema } from "../../utils/schema";

const title = "Best Racket Bags in India — For Badminton, Tennis, and Squash";
const description = "Best racket bags in India for 2026. Single, double, and 6-pack bags from Yonex, HEAD, and Li-Ning for all racket sports.";

const faqs = [
  { q: "What size racket bag do I need?", a: "If you carry one racket and minimal gear, a single or backpack-style bag is enough. Two rackets plus shoes and a change of clothes calls for a 3-racket bag. Serious players who carry multiple rackets, shoes, towels, and accessories should go for a 6-racket or larger tournament bag. Consider what you actually carry to every session rather than buying the biggest option." },
  { q: "Can I use a badminton bag for tennis rackets?", a: "Generally yes, but check dimensions. Standard badminton bags are designed for rackets up to 68cm long. Tennis rackets are 68-73cm. Most 6-racket badminton bags fit tennis rackets, but smaller single-racket badminton covers may be too short. Squash rackets at 68.5cm fit comfortably in most badminton bags." },
  { q: "Is a thermal compartment necessary?", a: "A thermal compartment protects your racket strings from extreme heat, which is especially important in India where car temperatures can exceed 60 degrees C. Heat loosens string tension and can warp frames. If you leave your bag in a car regularly, a thermal compartment is strongly recommended." },
  { q: "How do I clean a racket bag?", a: "Wipe the exterior with a damp cloth and mild soap. For the interior, turn it inside out if possible and air dry thoroughly. Never machine wash racket bags as it can damage padding and zippers. For odour, place baking soda or charcoal deodorisers inside overnight. Air out your bag after every session to prevent mould in humid Indian conditions." },
  { q: "What is the difference between a kit bag and a racket bag?", a: "A racket bag is specifically designed with compartments shaped for rackets, often with thermal protection. A kit bag is a general sports bag that can hold rackets along with other equipment. Racket bags offer better protection and organisation, while kit bags are more versatile for mixed-sport use." },
  { q: "Are expensive racket bags worth the investment?", a: "Premium bags (Rs 3,000+) offer better padding, thermal protection, more organised compartments, and superior zippers that last longer. If you own expensive rackets, a good bag protects your investment. Budget bags work fine if you are careful with your equipment and do not leave it in hot cars." },
];

const jsonLd = { "@graph": [
  webPageSchema({ url: "/reviews/best-racket-bags-india", name: title, description }),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Reviews", url: "/reviews" },
    { name: "Best Racket Bags", url: "/reviews/best-racket-bags-india" },
  ]),
  faqSchema(faqs),
] } as Record<string, unknown>;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Breadcrumbs -->
    <nav class="text-sm text-slate-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap gap-1">
        <li><a href="/" class="hover:text-green-600 transition-colors">Home</a></li>
        <li class="before:content-['/'] before:mx-2 before:text-slate-300"><a href="/reviews" class="hover:text-green-600 transition-colors">Reviews</a></li>
        <li class="before:content-['/'] before:mx-2 before:text-slate-300 text-slate-800 font-medium">Best Racket Bags</li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="mb-10">
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900 uppercase tracking-tight leading-tight">Best Racket Bags in India</h1>
      <p class="text-lg text-slate-600 mt-4 max-w-3xl">Whether you play badminton, tennis, or squash, your gear deserves proper protection. We review the best racket bags in India across every size and budget — from compact backpacks to full tournament bags.</p>
      <p class="text-sm text-slate-400 mt-2">Last updated: April 2026</p>
    </header>

    <div class="bg-slate-100 rounded-xl aspect-video flex items-center justify-center text-slate-400 text-sm my-8"><span>IMAGE: Assorted racket bags from Yonex, HEAD, and Li-Ning lined up against a court wall</span></div>

    <!-- Intro -->
    <section class="prose max-w-none mb-12">
      <p>A good racket bag does more than carry your rackets. It protects frames from heat damage, organises your shoes and accessories, and survives the daily commute without falling apart. In India, where summer temperatures can warp racket frames left in car boots, choosing the right bag with proper thermal insulation is not a luxury — it is a necessity.</p>
      <p>We used each bag for at least six weeks, loading them with rackets, shoes, water bottles, and towels to assess comfort, durability, compartment layout, and real-world usability. Here are our picks for every type of player.</p>
    </section>

    <!-- Bag Types -->
    <section class="mb-12">
      <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-6">Types of Racket Bags</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
          <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900">Single / Cover</h3>
          <p class="text-sm text-slate-600 mt-2">Slim padded sleeve for one racket. Lightest and most portable. Best for players who carry minimal gear and commute by public transport or two-wheeler. Rs 300-800.</p>
        </div>
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
          <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900">Double / 3-Pack</h3>
          <p class="text-sm text-slate-600 mt-2">Holds 2-3 rackets with a small accessory compartment. Good balance of capacity and portability. Fits a spare racket, grips, and a small towel. Rs 800-2,000.</p>
        </div>
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
          <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900">6-Pack / Tournament</h3>
          <p class="text-sm text-slate-600 mt-2">Professional-grade bag with 2-3 main compartments, shoe pocket, and accessory pockets. Often includes thermal lining. For serious players. Rs 2,500-6,000.</p>
        </div>
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
          <h3 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900">Backpack Style</h3>
          <p class="text-sm text-slate-600 mt-2">Holds 1-2 rackets in a backpack format with shoulder straps. Most comfortable for commuting. Great for players who cycle or use Metro. Rs 1,000-3,500.</p>
        </div>
      </div>
    </section>

    <!-- What to Look For -->
    <section class="mb-12 bg-slate-50 border border-slate-200 rounded-2xl p-6 sm:p-8">
      <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">What to Look For</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-sm mb-1">Thermal Protection</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Essential in India. A thermal-lined compartment keeps rackets safe from extreme heat in cars and storage. Look for silver or aluminium-lined interiors.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-sm mb-1">Shoe Compartment</h3>
            <p class="text-sm text-slate-500 leading-relaxed">A separate ventilated shoe pocket keeps your court shoes away from rackets and clothes. Ventilation prevents odour build-up, which is critical in Indian humidity.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-sm mb-1">Zipper Quality</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Cheap bags often fail at the zippers first. Look for metal or high-quality YKK-style zippers. Double-pull zippers are easier to use and distribute stress better.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-sm mb-1">Strap Comfort</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Padded, adjustable shoulder straps matter when you are carrying 3-5 kg of gear. Backpack-style straps distribute weight better than single shoulder straps for longer commutes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Picks -->
    <section class="mb-12">
      <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-6">Our Top Picks</h2>

      <!-- Yonex Pro Racquet Bag (6-pack) -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 my-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">Yonex Pro Racquet Bag (6-Pack)</h3>
            <p class="text-sm text-slate-500 mt-1">The premium choice for serious players. Three compartments, thermal lining, and the build quality Yonex is known for.</p>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Rs 5,490</span>
        </div>
        <div class="bg-slate-100 rounded-lg aspect-video flex items-center justify-center text-slate-400 text-sm mt-4"><span>IMAGE: Yonex Pro Racquet Bag 6-pack in black and green with multiple compartments visible</span></div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><h4 class="text-xs font-semibold text-green-700 uppercase mb-1">Pros</h4><ul class="text-sm text-slate-600 space-y-1"><li>Thermal-lined main compartment protects rackets from heat</li><li>Separate shoe compartment with ventilation</li><li>Fits both badminton and tennis rackets</li><li>Premium YKK zippers and reinforced stitching</li><li>Comfortable padded shoulder straps</li></ul></div>
          <div><h4 class="text-xs font-semibold text-red-600 uppercase mb-1">Cons</h4><ul class="text-sm text-slate-600 space-y-1"><li>Expensive — biggest investment on this list</li><li>Heavy when empty (1.8 kg)</li><li>Overkill for casual players with one racket</li></ul></div>
        </div>
      </div>

      <!-- HEAD Tour Team 6R -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 my-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">HEAD Tour Team 6R</h3>
            <p class="text-sm text-slate-500 mt-1">HEAD's popular mid-range tournament bag. Well-organised, durable, and perfectly sized for tennis and squash players.</p>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Rs 4,299</span>
        </div>
        <div class="bg-slate-100 rounded-lg aspect-video flex items-center justify-center text-slate-400 text-sm mt-4"><span>IMAGE: HEAD Tour Team 6R racket bag in navy blue with orange accents</span></div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><h4 class="text-xs font-semibold text-green-700 uppercase mb-1">Pros</h4><ul class="text-sm text-slate-600 space-y-1"><li>CCT+ technology for thermal protection</li><li>Two main compartments plus accessory pockets</li><li>Padded shoulder strap with air mesh</li><li>Generous shoe compartment fits up to size 11</li></ul></div>
          <div><h4 class="text-xs font-semibold text-red-600 uppercase mb-1">Cons</h4><ul class="text-sm text-slate-600 space-y-1"><li>Slightly shorter — tight fit for 27-inch tennis rackets with head covers</li><li>No backpack straps — shoulder carry only</li><li>Colours fade with prolonged sun exposure</li></ul></div>
        </div>
      </div>

      <!-- Li-Ning Badminton Kit Bag -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 my-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">Li-Ning Badminton Kit Bag</h3>
            <p class="text-sm text-slate-500 mt-1">Excellent mid-range option specifically designed for badminton. Spacious main compartment with smart internal organisation.</p>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Rs 2,999</span>
        </div>
        <div class="bg-slate-100 rounded-lg aspect-video flex items-center justify-center text-slate-400 text-sm mt-4"><span>IMAGE: Li-Ning Badminton Kit Bag in red and black with rackets visible</span></div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><h4 class="text-xs font-semibold text-green-700 uppercase mb-1">Pros</h4><ul class="text-sm text-slate-600 space-y-1"><li>Great value for a branded kit bag</li><li>Holds 4-6 badminton rackets comfortably</li><li>Water-resistant base material</li><li>Dedicated pockets for water bottle and valuables</li></ul></div>
          <div><h4 class="text-xs font-semibold text-red-600 uppercase mb-1">Cons</h4><ul class="text-sm text-slate-600 space-y-1"><li>No thermal lining</li><li>Tennis rackets may not fit lengthwise</li><li>Strap padding is thinner than Yonex or HEAD</li></ul></div>
        </div>
      </div>

      <!-- Yonex SUNR 23025 (Backpack) -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 my-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">Yonex SUNR 23025 (Backpack)</h3>
            <p class="text-sm text-slate-500 mt-1">The best racket backpack in India. Holds 1-2 rackets plus all your gear in a commute-friendly format.</p>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Rs 2,490</span>
        </div>
        <div class="bg-slate-100 rounded-lg aspect-video flex items-center justify-center text-slate-400 text-sm mt-4"><span>IMAGE: Yonex SUNR 23025 backpack-style racket bag with racket handle protruding from top</span></div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><h4 class="text-xs font-semibold text-green-700 uppercase mb-1">Pros</h4><ul class="text-sm text-slate-600 space-y-1"><li>Most comfortable commuting option — true backpack ergonomics</li><li>Dedicated racket compartment plus laptop/tablet sleeve</li><li>Perfect for Metro, bus, or two-wheeler commuters</li><li>Separate shoe compartment at the base</li></ul></div>
          <div><h4 class="text-xs font-semibold text-red-600 uppercase mb-1">Cons</h4><ul class="text-sm text-slate-600 space-y-1"><li>Only fits 1-2 rackets</li><li>No thermal lining</li><li>Racket handle sticks out the top — not fully enclosed</li></ul></div>
        </div>
      </div>

      <!-- HEAD Core 3R Pro -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 my-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">HEAD Core 3R Pro</h3>
            <p class="text-sm text-slate-500 mt-1">Compact 3-racket bag from HEAD that works beautifully for tennis, badminton, or squash. Clean design, solid build.</p>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Rs 2,199</span>
        </div>
        <div class="bg-slate-100 rounded-lg aspect-video flex items-center justify-center text-slate-400 text-sm mt-4"><span>IMAGE: HEAD Core 3R Pro racket bag in grey and black with HEAD branding</span></div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><h4 class="text-xs font-semibold text-green-700 uppercase mb-1">Pros</h4><ul class="text-sm text-slate-600 space-y-1"><li>Perfect size for 2-3 rackets plus essentials</li><li>Durable polyester construction</li><li>Adjustable shoulder strap with padding</li><li>Good value for a HEAD bag</li></ul></div>
          <div><h4 class="text-xs font-semibold text-red-600 uppercase mb-1">Cons</h4><ul class="text-sm text-slate-600 space-y-1"><li>No shoe compartment</li><li>No thermal lining at this price</li><li>Single main compartment — less organised than 6R bags</li></ul></div>
        </div>
      </div>

      <!-- Cosco Racket Kit Bag -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 my-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">Cosco Racket Kit Bag</h3>
            <p class="text-sm text-slate-500 mt-1">India's most affordable branded racket bag. No frills, but gets the basic job done for beginners and casual players.</p>
          </div>
          <span class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Rs 699</span>
        </div>
        <div class="bg-slate-100 rounded-lg aspect-video flex items-center justify-center text-slate-400 text-sm mt-4"><span>IMAGE: Cosco racket kit bag in blue and white, basic design</span></div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><h4 class="text-xs font-semibold text-green-700 uppercase mb-1">Pros</h4><ul class="text-sm text-slate-600 space-y-1"><li>Incredibly affordable</li><li>Holds 2-3 rackets (badminton or tennis)</li><li>Available in every sports shop across India</li><li>Light and easy to carry</li></ul></div>
          <div><h4 class="text-xs font-semibold text-red-600 uppercase mb-1">Cons</h4><ul class="text-sm text-slate-600 space-y-1"><li>Thin padding offers minimal racket protection</li><li>No thermal lining, shoe compartment, or organisation</li><li>Zippers are the weakest point — may fail within months</li><li>Material quality is basic</li></ul></div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="mb-12">
      <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-6">Quick Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-slate-200 rounded-xl overflow-hidden">
          <thead class="bg-slate-50">
            <tr>
              <th class="text-left px-4 py-3 font-semibold text-slate-700">Bag</th>
              <th class="text-left px-4 py-3 font-semibold text-slate-700">Price</th>
              <th class="text-left px-4 py-3 font-semibold text-slate-700">Type</th>
              <th class="text-left px-4 py-3 font-semibold text-slate-700">Capacity</th>
              <th class="text-left px-4 py-3 font-semibold text-slate-700">Thermal</th>
              <th class="text-left px-4 py-3 font-semibold text-slate-700">Shoe Pocket</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <tr><td class="px-4 py-3 text-slate-800 font-medium">Yonex Pro 6-Pack</td><td class="px-4 py-3 text-slate-600">Rs 5,490</td><td class="px-4 py-3 text-slate-600">Tournament</td><td class="px-4 py-3 text-slate-600">6 rackets</td><td class="px-4 py-3 text-green-600 font-medium">Yes</td><td class="px-4 py-3 text-green-600 font-medium">Yes</td></tr>
            <tr><td class="px-4 py-3 text-slate-800 font-medium">HEAD Tour Team 6R</td><td class="px-4 py-3 text-slate-600">Rs 4,299</td><td class="px-4 py-3 text-slate-600">Tournament</td><td class="px-4 py-3 text-slate-600">6 rackets</td><td class="px-4 py-3 text-green-600 font-medium">Yes</td><td class="px-4 py-3 text-green-600 font-medium">Yes</td></tr>
            <tr><td class="px-4 py-3 text-slate-800 font-medium">Li-Ning Kit Bag</td><td class="px-4 py-3 text-slate-600">Rs 2,999</td><td class="px-4 py-3 text-slate-600">Kit Bag</td><td class="px-4 py-3 text-slate-600">4-6 rackets</td><td class="px-4 py-3 text-slate-400">No</td><td class="px-4 py-3 text-slate-400">No</td></tr>
            <tr><td class="px-4 py-3 text-slate-800 font-medium">Yonex SUNR 23025</td><td class="px-4 py-3 text-slate-600">Rs 2,490</td><td class="px-4 py-3 text-slate-600">Backpack</td><td class="px-4 py-3 text-slate-600">1-2 rackets</td><td class="px-4 py-3 text-slate-400">No</td><td class="px-4 py-3 text-green-600 font-medium">Yes</td></tr>
            <tr><td class="px-4 py-3 text-slate-800 font-medium">HEAD Core 3R Pro</td><td class="px-4 py-3 text-slate-600">Rs 2,199</td><td class="px-4 py-3 text-slate-600">3-Pack</td><td class="px-4 py-3 text-slate-600">2-3 rackets</td><td class="px-4 py-3 text-slate-400">No</td><td class="px-4 py-3 text-slate-400">No</td></tr>
            <tr><td class="px-4 py-3 text-slate-800 font-medium">Cosco Kit Bag</td><td class="px-4 py-3 text-slate-600">Rs 699</td><td class="px-4 py-3 text-slate-600">Basic</td><td class="px-4 py-3 text-slate-600">2-3 rackets</td><td class="px-4 py-3 text-slate-400">No</td><td class="px-4 py-3 text-slate-400">No</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Related Guides -->
    <section class="mb-12 border-t border-slate-200 pt-10">
      <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">Badminton Buying Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <a href="/guides/how-to-choose-badminton-racket" class="group bg-white border border-slate-200 rounded-xl p-4 hover:shadow-md hover:border-green-300 transition-all">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors mb-1">How to Choose a Badminton Racket</p>
          <p class="text-xs text-slate-500">Weight, balance, shaft flex, and string tension explained.</p>
        </a>
        <a href="/guides/badminton-racket-weight-guide" class="group bg-white border border-slate-200 rounded-xl p-4 hover:shadow-md hover:border-green-300 transition-all">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors mb-1">Racket Weight Guide: 1U to 5U</p>
          <p class="text-xs text-slate-500">What the U system means and which weight suits you.</p>
        </a>
        <a href="/guides/best-badminton-racket-brands-india" class="group bg-white border border-slate-200 rounded-xl p-4 hover:shadow-md hover:border-green-300 transition-all">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors mb-1">Best Badminton Brands in India</p>
          <p class="text-xs text-slate-500">Yonex, Li-Ning, Victor, Apacs, Cosco compared.</p>
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(item => (
          <div class="border border-slate-200 rounded-xl overflow-hidden">
            <div class="bg-slate-50 px-5 py-3.5">
              <h3 class="font-semibold text-slate-900 text-sm">{item.q}</h3>
            </div>
            <div class="px-5 py-3.5">
              <p class="text-sm text-slate-600 leading-relaxed">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>
