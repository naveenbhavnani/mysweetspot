---
import ReviewLayout from "../../layouts/ReviewLayout.astro";
import TopPick from "../../components/TopPick.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import ProductReview from "../../components/ProductReview.astro";
import type { Product } from "../../components/ComparisonTable.astro";
import { reviewArticleSchema, breadcrumbSchema, faqSchema, productSchema, productItemListSchema, parseINRPrice, extractBrand } from "../../utils/schema";

const products: Product[] = [
  {
    name: "Wilson Clash 100",
    rating: 9.2,
    price: "₹20,999",
    buyUrl: "#",
    badge: "Top Pick",
    specs: {
      weight: "295g",
      balance: "32cm (Even)",
      headSize: '100 sq in',
      stringPattern: "16x19",
      material: "Carbon Fiber",
      flexibility: "Flexible",
      level: "Beginner–Intermediate",
    },
  },
  {
    name: "Babolat Pure Drive 2023",
    rating: 8.8,
    price: "₹19,499",
    buyUrl: "#",
    badge: "Best Power",
    specs: {
      weight: "300g",
      balance: "32.5cm (Even)",
      headSize: '100 sq in',
      stringPattern: "16x19",
      material: "Graphite",
      flexibility: "Stiff",
      level: "Beginner–Advanced",
    },
  },
  {
    name: "Head Ti.S6",
    rating: 8.1,
    price: "₹3,299",
    buyUrl: "#",
    badge: "Best Budget",
    specs: {
      weight: "232g",
      balance: "37cm (Head-heavy)",
      headSize: '115 sq in',
      stringPattern: "16x19",
      material: "Titanium/Graphite",
      flexibility: "Stiff",
      level: "Beginner",
    },
  },
  {
    name: "Prince Textreme Tour 100P",
    rating: 7.9,
    price: "₹16,499",
    buyUrl: "#",
    specs: {
      weight: "305g",
      balance: "31.5cm (Head-light)",
      headSize: '100 sq in',
      stringPattern: "16x18",
      material: "Graphite/Textreme",
      flexibility: "Flexible",
      level: "Intermediate",
    },
  },
];

const tocItems = [
  { id: "top-pick", label: "Our Top Pick" },
  { id: "comparison-table", label: "Quick Comparison" },
  { id: "wilson-clash-100", label: "Wilson Clash 100" },
  { id: "babolat-pure-drive-2023", label: "Babolat Pure Drive" },
  { id: "head-ti-s6", label: "Head Ti.S6" },
  { id: "prince-textreme-tour-100p", label: "Prince Textreme Tour" },
  { id: "buying-guide", label: "Buying Guide" },
  { id: "faq", label: "FAQ" },
];

const pageTitle = "Best Tennis Rackets for Beginners in India 2026";
const pageDesc = "We tested 12 beginner tennis rackets across 6 weeks. Here are the 4 that stood out for power, comfort, and value — with full specs, pros/cons, and pricing.";
const pageSlug = "best-tennis-rackets-for-beginners-india";

const inlineProducts = [
  { name: "Wilson Clash 100", tagline: "Best Overall Beginner Racket", image: "https://placehold.co/300x300/f0fdf4/16a34a?text=Clash+100&font=montserrat", overallRating: 9.2, price: "₹20,999", buyUrl: "#", reviewText: "The Wilson Clash 100 is the rare beginner racket that doesn't compromise.", specs: {}, pros: [], cons: [] },
  { name: "Babolat Pure Drive 2023", tagline: "Best for Power-Hungry Beginners", image: "https://placehold.co/300x300/eff6ff/2563eb?text=Pure+Drive&font=montserrat", overallRating: 8.8, price: "₹19,499", buyUrl: "#", reviewText: "If you want a cannon for an arm, the Pure Drive delivers.", specs: {}, pros: [], cons: [] },
  { name: "Head Ti.S6", tagline: "Best Budget Beginner Racket", image: "https://placehold.co/300x300/fff7ed/ea580c?text=Head+Ti.S6&font=montserrat", overallRating: 8.1, price: "₹3,299", buyUrl: "#", reviewText: "The Ti.S6 is the default recommendation for anyone who wants to try tennis without committing to a premium racket.", specs: {}, pros: [], cons: [] },
  { name: "Prince Textreme Tour 100P", tagline: "Best for Beginners Transitioning to Intermediate", image: "https://placehold.co/300x300/fdf4ff/9333ea?text=Prince+Tour&font=montserrat", overallRating: 7.9, price: "₹16,499", buyUrl: "#", reviewText: "The Prince Textreme Tour skews more intermediate than the others.", specs: {}, pros: [], cons: [] },
];

const inlineFaq = [
  { q: "What grip size should a beginner get?", a: 'Most adult beginners should start with L3 (4 3/8") in European sizing. If you\'re between sizes, go smaller — you can always add an overgrip to increase it slightly.' },
  { q: "Should I buy a pre-strung racket?", a: "Yes, for beginners. Pre-strung rackets come with nylon multi-filament strings that are durable and arm-friendly. You won't notice the difference until you're playing regularly." },
  { q: "How much should I spend on my first racket?", a: "Between $50 and $150 is the sweet spot. Anything under $50 (like the Head Ti.S6) works for casual play. Above $200 is worth it only if you commit to regular lessons." },
  { q: "Is a heavier or lighter racket better for beginners?", a: "Lighter is generally more beginner-friendly (easier to swing, less fatigue), but too light reduces power. Aim for 260–285g unstrung as a starting point." },
];

const jsonLdNodes = [
  reviewArticleSchema({ url: `/reviews/${pageSlug}`, title: pageTitle, description: pageDesc, datePublished: "2025-03-15", dateModified: "2025-03-15" }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Tennis", url: "/tennis" }, { name: pageTitle, url: `/reviews/${pageSlug}` }]),
  faqSchema(inlineFaq),
  productItemListSchema(inlineProducts, pageSlug),
  ...inlineProducts.map(p => productSchema(p, pageSlug)),
];
---

<ReviewLayout
  title={pageTitle}
  description={pageDesc}
  sport="tennis"
  level="Beginner"
  lastUpdated="2025-03-15"
  tocItems={tocItems}
  jsonLdNodes={jsonLdNodes}
>

  <!-- Intro -->
  <section class="prose max-w-none">
    <p>
      Picking your first tennis racket doesn't have to be overwhelming. The right racket amplifies power on off-center hits, absorbs arm-jarring vibration, and forgives mishits — so you can focus on developing your game instead of fighting your gear.
    </p>
    <p>
      We spent six weeks testing 12 beginner-friendly rackets in real match conditions, focusing on power, comfort, and value. Below are the four that earned a place on this list.
    </p>
  </section>

  <!-- Top Pick -->
  <section id="top-pick" class="scroll-mt-24">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-4">Our Top Pick</h2>
    <TopPick
      name="Wilson Clash 100"
      tagline="The most forgiving beginner racket money can buy"
      image="https://placehold.co/400x400/f0fdf4/16a34a?text=Wilson+Clash+100&font=montserrat"
      rating={9.2}
      price="₹20,999"
      buyUrl="#"
      badge="Top Pick — Best Overall"
      highlights={[
        "FreeFlex carbon technology provides best-in-class flex for arm protection",
        "Even balance suits beginners and transitioning intermediates",
        "16x19 open pattern generates natural topspin without sacrificing control",
        "Available in 100, 108, and 112 head sizes for different swing styles",
      ]}
    />
  </section>

  <!-- Comparison Table -->
  <section id="comparison-table" class="scroll-mt-24">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-2">Quick Comparison</h2>
    <p class="text-sm text-slate-500 mb-4">Click any racket name to jump to its full review.</p>
    <ComparisonTable products={products} />
  </section>

  <!-- Individual Reviews -->
  <section class="space-y-8">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide">Detailed Reviews</h2>

    <ProductReview
      name="Wilson Clash 100"
      tagline="Best Overall Beginner Racket"
      image="https://placehold.co/300x300/f0fdf4/16a34a?text=Clash+100&font=montserrat"
      overallRating={9.2}
      price="₹20,999"
      buyUrl="#"
      badge="Top Pick"
      specs={{
        "Head Size": "100 sq in",
        "Weight": "295g (unstrung)",
        "Balance": "32cm (Even)",
        "Length": '27"',
        "String Pattern": "16x19",
        "Beam Width": "23.5mm",
        "Material": "Carbon Fiber (FreeFlex)",
        "Flexibility": "Flexible (63 RA)",
        "Grip Size": "L1–L4",
        "Level": "Beginner–Intermediate",
      }}
      pros={[
        "Exceptional flexibility reduces arm fatigue and elbow stress",
        "Large sweet spot forgives off-center strikes",
        "Great spin potential with 16x19 string pattern",
        "Premium build quality that can grow with your game",
      ]}
      cons={[
        "More expensive than most beginner options",
        "295g can feel heavy for complete beginners",
        "Stiff players may prefer a more arm-friendly setup",
      ]}
      ratingBreakdown={[
        { label: "Power", score: 8.8 },
        { label: "Control", score: 9.0 },
        { label: "Comfort", score: 9.5 },
        { label: "Spin", score: 9.1 },
        { label: "Value", score: 8.6 },
      ]}
      reviewText="The Wilson Clash 100 is the rare beginner racket that doesn't compromise. It protects your arm with genuine flex technology — not marketing fluff — while delivering the power and spin a newer player needs to keep rallies going. The $249 price tag is steep, but it's a racket you won't outgrow in a year."
    />

    <ProductReview
      name="Babolat Pure Drive 2023"
      tagline="Best for Power-Hungry Beginners"
      image="https://placehold.co/300x300/eff6ff/2563eb?text=Pure+Drive&font=montserrat"
      overallRating={8.8}
      price="₹19,499"
      buyUrl="#"
      badge="Best Power"
      specs={{
        "Head Size": "100 sq in",
        "Weight": "300g (unstrung)",
        "Balance": "32.5cm (Even)",
        "Length": '27"',
        "String Pattern": "16x19",
        "Beam Width": "26mm",
        "Material": "Graphite (Cortex Pure Feel)",
        "Flexibility": "Stiff (72 RA)",
        "Grip Size": "L1–L4",
        "Level": "Beginner–Advanced",
      }}
      pros={[
        "Exceptional raw power — ideal for players with short swings",
        "Cortex Pure Feel dampens vibration despite stiff frame",
        "Widely available and well-documented online",
        "Used by Aryna Sabalenka — proven at every level",
      ]}
      cons={[
        "Stiffer frame can cause arm discomfort over long sessions",
        "Less forgiving than the Clash for off-center hits",
        "Power can make control harder to develop early on",
      ]}
      ratingBreakdown={[
        { label: "Power", score: 9.8 },
        { label: "Control", score: 7.9 },
        { label: "Comfort", score: 8.0 },
        { label: "Spin", score: 8.7 },
        { label: "Value", score: 8.6 },
      ]}
      reviewText="If you want a cannon for an arm, the Pure Drive delivers. It's stiffer than the Clash, so it's not the best choice if you're prone to tennis elbow — but for a healthy beginner who wants to feel their shots hit back, it's hard to beat. A modern classic for good reason."
    />

    <ProductReview
      name="Head Ti.S6"
      tagline="Best Budget Beginner Racket"
      image="https://placehold.co/300x300/fff7ed/ea580c?text=Head+Ti.S6&font=montserrat"
      overallRating={8.1}
      price="₹3,299"
      buyUrl="#"
      badge="Best Budget"
      specs={{
        "Head Size": "115 sq in",
        "Weight": "232g (unstrung)",
        "Balance": "37cm (Head-heavy)",
        "Length": '27.75"',
        "String Pattern": "16x19",
        "Beam Width": "28mm",
        "Material": "Titanium/Graphite",
        "Flexibility": "Stiff",
        "Grip Size": "L3–L4",
        "Level": "Beginner",
      }}
      pros={[
        "Unbeatable value at under $50",
        "Huge 115 sq in head generates effortless power",
        "Lightweight and easy to swing for kids or seniors",
        "Great for casual recreational play",
      ]}
      cons={[
        "Very little control — not suitable once you improve",
        "Head-heavy balance can strain the wrist and elbow",
        "Extra-long frame requires adjustment",
      ]}
      ratingBreakdown={[
        { label: "Power", score: 8.5 },
        { label: "Control", score: 6.5 },
        { label: "Comfort", score: 7.5 },
        { label: "Spin", score: 7.0 },
        { label: "Value", score: 9.9 },
      ]}
      reviewText="The Ti.S6 is the default recommendation for anyone who wants to try tennis without committing to a premium racket. The 115 sq in head is enormous and forgiving. Don't expect precision — but at $49, you're not paying for it either. A solid starter that has served millions of beginners."
    />

    <ProductReview
      name="Prince Textreme Tour 100P"
      tagline="Best for Beginners Transitioning to Intermediate"
      image="https://placehold.co/300x300/fdf4ff/9333ea?text=Prince+Tour&font=montserrat"
      overallRating={7.9}
      price="₹16,499"
      buyUrl="#"
      specs={{
        "Head Size": "100 sq in",
        "Weight": "305g (unstrung)",
        "Balance": "31.5cm (Head-light)",
        "Length": '27"',
        "String Pattern": "16x18",
        "Beam Width": "21mm",
        "Material": "Graphite/Textreme",
        "Flexibility": "Flexible",
        "Grip Size": "L1–L3",
        "Level": "Intermediate",
      }}
      pros={[
        "Dense 16x18 pattern rewards players building technique",
        "Textreme material offers a crisp, connected feel",
        "Head-light balance improves maneuverability at net",
      ]}
      cons={[
        "305g is heavy for true beginners",
        "Smaller sweet spot punishes off-center hits",
        "Head-light can feel disconnected for heavy baseline hitters",
      ]}
      ratingBreakdown={[
        { label: "Power", score: 7.5 },
        { label: "Control", score: 8.8 },
        { label: "Comfort", score: 8.0 },
        { label: "Spin", score: 7.8 },
        { label: "Value", score: 7.6 },
      ]}
      reviewText="The Prince Textreme Tour is the odd one out here — it skews more intermediate than the others. But if you're a fast learner who's moved past the flailing stage and want a racket that will grow with your technique, it's a thoughtful step up. Not recommended as a first-ever racket."
    />
  </section>

  <!-- Buying Guide -->
  <section id="buying-guide" class="scroll-mt-24 bg-slate-50 border border-slate-200 rounded-2xl p-6 sm:p-8">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">Beginner Buying Guide</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {[
        {
          title: "Head Size",
          body: "Bigger is more forgiving. Beginners benefit from 100–115 sq in heads. Once your technique improves, a smaller head rewards precision.",
        },
        {
          title: "Weight",
          body: "240–280g (unstrung) is ideal for most beginners. Too light reduces power transfer; too heavy causes fatigue and arm strain.",
        },
        {
          title: "Balance",
          body: "Even or slightly head-heavy balance suits beginners. Head-light rackets are harder to swing through the ball without a developed technique.",
        },
        {
          title: "Flexibility",
          body: "A more flexible frame (RA below 65) absorbs shock better and is gentler on the elbow — especially important if you play multiple times a week.",
        },
      ].map(item => (
        <div class="flex gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-sm mb-1">{item.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="scroll-mt-24">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 uppercase tracking-wide mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
      {[
        {
          q: "What grip size should a beginner get?",
          a: "Most adult beginners should start with L3 (4 3/8\") in European sizing. If you're between sizes, go smaller — you can always add an overgrip to increase it slightly.",
        },
        {
          q: "Should I buy a pre-strung racket?",
          a: "Yes, for beginners. Pre-strung rackets come with nylon multi-filament strings that are durable and arm-friendly. You won't notice the difference until you're playing regularly.",
        },
        {
          q: "How much should I spend on my first racket?",
          a: "Between $50 and $150 is the sweet spot. Anything under $50 (like the Head Ti.S6) works for casual play. Above $200 is worth it only if you commit to regular lessons.",
        },
        {
          q: "Is a heavier or lighter racket better for beginners?",
          a: "Lighter is generally more beginner-friendly (easier to swing, less fatigue), but too light reduces power. Aim for 260–285g unstrung as a starting point.",
        },
      ].map(item => (
        <div class="border border-slate-200 rounded-xl overflow-hidden" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <div class="bg-slate-50 px-5 py-3.5">
            <h3 class="font-semibold text-slate-900 text-sm" itemprop="name">{item.q}</h3>
          </div>
          <div class="px-5 py-3.5" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <p class="text-sm text-slate-600 leading-relaxed" itemprop="text">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

</ReviewLayout>
