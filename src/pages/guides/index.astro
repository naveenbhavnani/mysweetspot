---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { webPageSchema, breadcrumbSchema } from "../../utils/schema";

const badmintonGuides = [
  { title: "How to Choose a Badminton Racket", desc: "Weight, balance, shaft flex, head shape, and string tension — everything explained for Indian players.", href: "/guides/how-to-choose-badminton-racket", img: "/images/guides/badminton/choose-badminton-racket-hero.png" },
  { title: "Racket Weight Guide: 1U to 5U", desc: "What the U system means, which weight suits your play style, and popular rackets in each class.", href: "/guides/badminton-racket-weight-guide", img: "/images/guides/badminton/badminton-weight-guide-hero.png" },
  { title: "Best Badminton Brands in India", desc: "Yonex, Li-Ning, Victor, Apacs, Cosco, and Carlton — ranked and compared.", href: "/guides/best-badminton-racket-brands-india", img: "/images/guides/badminton/best-badminton-brands-hero.png" },
];

const tennisGuides = [
  { title: "How to Choose a Tennis Racket for Beginners", desc: "Head size, weight, balance, material, and budget recommendations for Indian beginners.", href: "/guides/how-to-choose-tennis-racket-beginners", img: "/images/guides/tennis/choose-tennis-racket-beginners-hero.png" },
  { title: "Tennis Racket Grip Size Guide", desc: "Two proven methods to measure your grip size, plus the complete sizing chart.", href: "/guides/tennis-racket-grip-size-guide", img: "/images/guides/tennis/tennis-grip-size-guide-hero.png" },
  { title: "Graphite vs Aluminium vs Carbon Fibre", desc: "Material differences, who each suits, and what it costs in India.", href: "/guides/graphite-vs-aluminium-vs-carbon-fibre-tennis-rackets", img: "/images/guides/tennis/choose-tennis-racket-frame-materials.png" },
];

const jsonLd = { "@graph": [
  webPageSchema({ url: "/guides", name: "Buying Guides", description: "In-depth racket sport buying guides for Indian players. Learn how to choose the right racket, understand specs, and compare brands." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Guides", url: "/guides" }]),
] } as Record<string, unknown>;
---

<BaseLayout
  title="Buying Guides"
  description="In-depth racket sport buying guides for Indian players. Learn how to choose the right racket, understand specs, and compare brands."
  jsonLd={jsonLd}
>
  <div class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Guides</span>
      </nav>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Buying Guides</h1>
      <p class="mt-3 text-slate-500 text-base max-w-2xl">In-depth guides to help you understand specs, compare options, and make smarter buying decisions.</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-14">

    <!-- Badminton -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <span class="w-3 h-3 rounded-full bg-cyan-500" aria-hidden="true"></span>
        <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Badminton</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {badmintonGuides.map(g => (
          <a href={g.href} class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-cyan-300 transition-all">
            <img src={g.img} alt={g.title} class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
            <div class="p-4">
              <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">{g.title}</p>
              <p class="text-xs text-slate-500 mt-1 leading-relaxed">{g.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Tennis -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <span class="w-3 h-3 rounded-full bg-lime-500" aria-hidden="true"></span>
        <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900">Tennis</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {tennisGuides.map(g => (
          <a href={g.href} class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-lime-300 transition-all">
            <img src={g.img} alt={g.title} class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
            <div class="p-4">
              <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">{g.title}</p>
              <p class="text-xs text-slate-500 mt-1 leading-relaxed">{g.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
