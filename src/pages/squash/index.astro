---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RatingBadge from "../../components/RatingBadge.astro";
import { collectionPageSchema, breadcrumbSchema, itemListSchema } from "../../utils/schema";

const reviews = [
  { title: "Best Squash Rackets Under 3000 in India 2026", href: "/reviews/best-squash-rackets-under-3000-india", topPick: "HEAD Nano Ti Graphite Spector 2.0", price: "₹2,630", rating: 9.3, level: "Beginner" },
];

const jsonLd = { "@graph": [
  collectionPageSchema({ url: "/squash", name: "Squash Racket Reviews", description: "Independent squash racket reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Squash", url: "/squash" }]),
  itemListSchema(reviews.map(r => ({ name: r.title, url: r.href }))),
] } as Record<string, unknown>;
---

<BaseLayout title="Squash Racket Reviews" description="Independent squash racket reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing." jsonLd={jsonLd}>
  <div class="bg-violet-50 border-b border-violet-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb"><a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Squash</span></nav>
      <div class="flex items-center gap-3 mb-3"><span class="w-3 h-3 rounded-full bg-violet-500" aria-hidden="true"></span><span class="text-xs font-semibold text-violet-700 uppercase tracking-widest">Squash</span></div>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Squash Racket Reviews</h1>
      <p class="mt-3 text-slate-500 text-base max-w-xl">Every racket tested in real play. Honest ratings, full specs, and Indian pricing.</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-4">
    {reviews.map(r => (
      <article class="bg-white border border-slate-200 rounded-2xl p-5 flex flex-col sm:flex-row items-start gap-4 hover:shadow-md transition-shadow">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            {r.level && <span class="text-xs font-medium text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full">{r.level}</span>}
          </div>
          <h2 class="font-[Barlow_Condensed] text-lg font-bold text-slate-900">
            <a href={r.href} class="hover:text-green-600 transition-colors">{r.title}</a>
          </h2>
          <div class="mt-2 flex items-center gap-4 flex-wrap">
            <div>
              <p class="text-xs text-slate-400">Top Pick</p>
              <p class="text-sm font-semibold text-slate-800">{r.topPick} · <span class="font-[Barlow_Condensed] text-base">{r.price}</span></p>
            </div>
            <a href={r.href} class="ml-auto text-sm font-semibold text-green-600 hover:underline">Read review →</a>
          </div>
        </div>
        <RatingBadge score={r.rating} size="md" />
      </article>
    ))}
  </div>
</BaseLayout>
