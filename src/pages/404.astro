---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page Not Found" noindex={true}>
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="font-[Barlow_Condensed] text-8xl font-bold text-slate-900 mb-4">404</p>
    <h1 class="font-[Barlow_Condensed] text-3xl font-bold text-slate-900 mb-3">Page Not Found</h1>
    <p class="text-slate-500 text-sm mb-8">This page doesn't exist or may have moved. Try browsing by sport below.</p>
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      {[
        { label: "Tennis", href: "/tennis", color: "bg-lime-100 text-lime-800 hover:bg-lime-200" },
        { label: "Badminton", href: "/badminton", color: "bg-cyan-100 text-cyan-800 hover:bg-cyan-200" },
        { label: "Pickleball", href: "/pickleball", color: "bg-orange-100 text-orange-800 hover:bg-orange-200" },
        { label: "Squash", href: "/squash", color: "bg-violet-100 text-violet-800 hover:bg-violet-200" },
      ].map(s => (
        <a href={s.href} class={`px-4 py-2 rounded-full text-sm font-semibold transition-colors ${s.color}`}>{s.label}</a>
      ))}
    </div>
    <a href="/" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl transition-colors">← Back to Home</a>
  </div>
</BaseLayout>
