---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RatingBadge from "../../components/RatingBadge.astro";
import { collectionPageSchema, breadcrumbSchema, itemListSchema } from "../../utils/schema";

const reviews = [
  {
    title: "Best Table Tennis Tables in India 2026",
    desc: "5 full-size tables compared. Step Over Tournament Pro 25mm leads with its tournament-grade surface and exceptional value.",
    href: "/reviews/best-table-tennis-tables-india",
    topPick: "Step Over Tournament Pro 25mm",
    price: "₹18,499",
    rating: 9.6,
    lastUpdated: "Apr 2026",
  },
  {
    title: "Best Table Tennis Rackets Under 5000 in India 2026",
    desc: "8 mid-range rackets evaluated. TANSO Black X Blade Pro tops the list with ALC carbon performance at an unbeatable price.",
    href: "/reviews/best-table-tennis-rackets-under-5000-india",
    topPick: "TANSO Black X Blade Pro",
    price: "₹2,199",
    rating: 9.4,
    lastUpdated: "Apr 2026",
  },
  {
    title: "Best Table Tennis Rackets Under 2000 in India 2026",
    desc: "5 budget rackets tested. GKI Offensive XX is the #1 Amazon bestseller with TTFI approval and balanced all-round performance.",
    href: "/reviews/best-table-tennis-rackets-under-2000-india",
    topPick: "GKI Offensive XX",
    price: "₹980",
    rating: 9.3,
    lastUpdated: "Apr 2026",
  },
];

const jsonLd = { "@graph": [
  collectionPageSchema({ url: "/table-tennis", name: "Table Tennis Reviews", description: "Independent table tennis reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Table Tennis", url: "/table-tennis" }]),
  itemListSchema(reviews.map(r => ({ name: r.title, url: r.href }))),
] } as Record<string, unknown>;
---

<BaseLayout
  title="Table Tennis Reviews"
  description="Independent table tennis reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing."
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <div class="bg-blue-50 border-b border-blue-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Table Tennis</span>
      </nav>
      <div class="flex items-center gap-3 mb-3">
        <span class="w-3 h-3 rounded-full bg-blue-500" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-blue-700 uppercase tracking-widest">Table Tennis</span>
      </div>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Table Tennis Reviews</h1>
      <p class="mt-3 text-slate-500 text-base max-w-xl">Tables and rackets tested with real play sessions. Honest ratings, full specs, and Indian pricing.</p>
    </div>
  </div>

  <!-- Review list -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-sm text-slate-400 mb-6">{reviews.length} review{reviews.length !== 1 ? "s" : ""} published</p>

    <div class="space-y-4">
      {reviews.map(r => (
        <a href={r.href} class="block group">
          <article class="bg-white border border-slate-200 rounded-2xl p-5 flex flex-col sm:flex-row gap-5 group-hover:shadow-md group-hover:border-slate-300 transition-all">
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div>
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-xs text-slate-400">Updated {r.lastUpdated}</span>
                  </div>
                  <h2 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900 group-hover:text-green-600 transition-colors">{r.title}</h2>
                  <p class="text-sm text-slate-500 mt-1">{r.desc}</p>
                </div>
                <RatingBadge score={r.rating} size="md" />
              </div>
              <div class="mt-3 flex items-center gap-4 flex-wrap">
                <div>
                  <p class="text-xs text-slate-400">Top Pick</p>
                  <p class="text-sm font-semibold text-slate-800">{r.topPick} · <span class="font-[Barlow_Condensed] text-base">{r.price}</span></p>
                </div>
                <span class="ml-auto text-sm font-semibold text-green-600 group-hover:underline">Read review →</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>

</BaseLayout>
