---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RatingBadge from "../../components/RatingBadge.astro";
import { collectionPageSchema, breadcrumbSchema, itemListSchema } from "../../utils/schema";

const reviews = [
{
    title: "Best Tennis Rackets Under 5000 in India 2026",
    desc: "Budget picks under ₹5000. HEAD Titanium Tour Pro tops the list for its lightweight power and massive sweet spot.",
    href: "/reviews/best-tennis-rackets-under-5000-india",
    topPick: "HEAD Titanium Tour Pro",
    price: "₹3,237",
    rating: 9.5,
    level: "Beginner",
    lastUpdated: "Apr 2026",
  },
  {
    title: "Best Tennis Rackets Under 10000 in India 2026",
    desc: "Mid-range rackets under ₹10,000. HEAD TI S6 leads with its oversized head and featherweight feel.",
    href: "/reviews/best-tennis-rackets-under-10000-india",
    topPick: "HEAD TI S6",
    price: "₹10,499",
    rating: 9.3,
    level: "Beginner–Intermediate",
    lastUpdated: "Apr 2026",
  },
  {
    title: "Best Tennis Rackets Under 20000 in India 2026",
    desc: "Performance rackets under ₹20,000. HEAD Radical Pro 2023 delivers tour-level control at an accessible price.",
    href: "/reviews/best-tennis-rackets-under-20000-india",
    topPick: "HEAD Radical Pro 2023",
    price: "₹17,708",
    rating: 9.4,
    level: "Intermediate",
    lastUpdated: "Apr 2026",
  },
];

const jsonLd = { "@graph": [
  collectionPageSchema({ url: "/tennis", name: "Tennis Racket Reviews", description: "Independent tennis racket reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Tennis", url: "/tennis" }]),
  itemListSchema(reviews.map(r => ({ name: r.title, url: r.href }))),
] } as Record<string, unknown>;
---

<BaseLayout
  title="Tennis Racket Reviews"
  description="Independent tennis racket reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing."
  jsonLd={jsonLd}
>
  <div class="bg-lime-50 border-b border-lime-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Tennis</span>
      </nav>
      <div class="flex items-center gap-3 mb-3">
        <span class="w-3 h-3 rounded-full bg-lime-500" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-lime-700 uppercase tracking-widest">Tennis</span>
      </div>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Tennis Racket Reviews</h1>
      <p class="mt-3 text-slate-500 text-base max-w-xl">Every racket tested in real play sessions. Honest ratings, full specs, and Indian pricing.</p>
    </div>
  </div>
  <!-- Guides -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 mb-2">Buying Guides</h2>
    <p class="text-sm text-slate-500 mb-6">In-depth guides to help you pick the right racket and understand the specs.</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/guides/how-to-choose-tennis-racket-beginners" class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-lime-300 transition-all">
        <img src="/images/guides/tennis/choose-tennis-racket-beginners-hero.png" alt="How to choose a tennis racket for beginners" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
        <div class="p-4">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">How to Choose a Tennis Racket for Beginners</p>
          <p class="text-xs text-slate-500 mt-1">Head size, weight, balance, material, and budget recommendations.</p>
        </div>
      </a>
      <a href="/guides/tennis-racket-grip-size-guide" class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-lime-300 transition-all">
        <img src="/images/guides/tennis/tennis-grip-size-guide-hero.png" alt="Tennis racket grip size guide" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
        <div class="p-4">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">Grip Size Guide</p>
          <p class="text-xs text-slate-500 mt-1">How to measure your hand and find the right grip size.</p>
        </div>
      </a>
      <a href="/guides/graphite-vs-aluminium-vs-carbon-fibre-tennis-rackets" class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-lime-300 transition-all">
        <img src="/images/guides/tennis/choose-tennis-racket-frame-materials.png" alt="Graphite vs aluminium vs carbon fibre tennis rackets" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
        <div class="p-4">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">Graphite vs Aluminium vs Carbon Fibre</p>
          <p class="text-xs text-slate-500 mt-1">Material differences, performance impact, and Indian pricing.</p>
        </div>
      </a>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-sm text-slate-400 mb-6">{reviews.length} review{reviews.length !== 1 ? "s" : ""} published</p>
    <div class="space-y-4">
      {reviews.map(r => (
        <a href={r.href} class="block group">
          <article class="bg-white border border-slate-200 rounded-2xl p-5 flex flex-col sm:flex-row gap-5 group-hover:shadow-md group-hover:border-slate-300 transition-all">
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div>
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-xs font-semibold text-lime-700 bg-lime-100 px-2 py-0.5 rounded-full">{r.level}</span>
                    <span class="text-xs text-slate-400">Updated {r.lastUpdated}</span>
                  </div>
                  <h2 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900 group-hover:text-green-600 transition-colors">{r.title}</h2>
                  <p class="text-sm text-slate-500 mt-1">{r.desc}</p>
                </div>
                <RatingBadge score={r.rating} size="md" />
              </div>
              <div class="mt-3 flex items-center gap-4 flex-wrap">
                <div>
                  <p class="text-xs text-slate-400">Top Pick</p>
                  <p class="text-sm font-semibold text-slate-800">{r.topPick} · <span class="font-[Barlow_Condensed] text-base">{r.price}</span></p>
                </div>
                <span class="ml-auto text-sm font-semibold text-green-600 group-hover:underline">Read review →</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
