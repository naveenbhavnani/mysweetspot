---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RatingBadge from "../../components/RatingBadge.astro";
import { collectionPageSchema, breadcrumbSchema, itemListSchema } from "../../utils/schema";

const sport = "badminton";
const sportColor = "cyan";

const reviews = [
  {
    title: "Best Badminton Rackets Under 2000 in India 2026",
    desc: "5 tested, graphite-only picks for beginners and casual players. Yonex Nanoray Light 18i leads the pack.",
    href: "/reviews/best-badminton-rackets-under-2000-india",
    topPick: "Yonex Nanoray Light 18i",
    price: "₹1,799",
    rating: 9.0,
    level: "Beginner",
    lastUpdated: "Apr 2026",
  },
  {
    title: "Best Badminton Rackets Under 5000 in India 2026",
    desc: "Mid-range rackets under ₹5000. Yonex Astrox 77 Play earns top spot for its explosive smash power.",
    href: "/reviews/best-badminton-rackets-under-5000-india",
    topPick: "Yonex Astrox 77 Play",
    price: "₹2,890",
    rating: 9.5,
    level: "Intermediate",
    lastUpdated: "Apr 2026",
  },
];

const jsonLd = { "@graph": [
  collectionPageSchema({ url: "/badminton", name: "Badminton Racket Reviews", description: "Independent badminton racket reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Badminton", url: "/badminton" }]),
  itemListSchema(reviews.map(r => ({ name: r.title, url: r.href }))),
] } as Record<string, unknown>;
---

<BaseLayout
  title="Badminton Racket Reviews"
  description="Independent badminton racket reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing."
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <div class="bg-cyan-50 border-b border-cyan-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Badminton</span>
      </nav>
      <div class="flex items-center gap-3 mb-3">
        <span class="w-3 h-3 rounded-full bg-cyan-500" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-cyan-700 uppercase tracking-widest">Badminton</span>
      </div>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Badminton Racket Reviews</h1>
      <p class="mt-3 text-slate-500 text-base max-w-xl">Every racket tested in real play sessions. Honest ratings, full specs, and Indian pricing — no fluff.</p>
    </div>
  </div>

  <!-- Guides -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <h2 class="font-[Barlow_Condensed] text-2xl font-bold text-slate-900 mb-2">Buying Guides</h2>
    <p class="text-sm text-slate-500 mb-6">In-depth guides to help you make the right choice before you buy.</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/guides/how-to-choose-badminton-racket" class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-cyan-300 transition-all">
        <img src="/images/guides/badminton/choose-badminton-racket-hero.png" alt="How to choose a badminton racket" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
        <div class="p-4">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">How to Choose a Badminton Racket</p>
          <p class="text-xs text-slate-500 mt-1">Weight, balance, shaft flex, head shape, and string tension explained.</p>
        </div>
      </a>
      <a href="/guides/badminton-racket-weight-guide" class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-cyan-300 transition-all">
        <img src="/images/guides/badminton/badminton-weight-guide-hero.png" alt="Badminton racket weight guide" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
        <div class="p-4">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">Racket Weight Guide: 1U to 5U</p>
          <p class="text-xs text-slate-500 mt-1">What the U system means and which weight suits your play style.</p>
        </div>
      </a>
      <a href="/guides/best-badminton-racket-brands-india" class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-md hover:border-cyan-300 transition-all">
        <img src="/images/guides/badminton/best-badminton-brands-hero.png" alt="Best badminton brands in India" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" />
        <div class="p-4">
          <p class="font-semibold text-slate-900 text-sm group-hover:text-green-600 transition-colors">Best Badminton Brands in India</p>
          <p class="text-xs text-slate-500 mt-1">Yonex, Li-Ning, Victor, Apacs, Cosco, and Carlton compared.</p>
        </div>
      </a>
    </div>
  </div>

  <!-- Review list -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-sm text-slate-400 mb-6">{reviews.length} review{reviews.length !== 1 ? "s" : ""} published</p>

    <div class="space-y-4">
      {reviews.map(r => (
        <a href={r.href} class="block group">
          <article class="bg-white border border-slate-200 rounded-2xl p-5 flex flex-col sm:flex-row gap-5 group-hover:shadow-md group-hover:border-slate-300 transition-all">
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div>
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-xs font-semibold text-cyan-700 bg-cyan-100 px-2 py-0.5 rounded-full">{r.level}</span>
                    <span class="text-xs text-slate-400">Updated {r.lastUpdated}</span>
                  </div>
                  <h2 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900 group-hover:text-green-600 transition-colors">{r.title}</h2>
                  <p class="text-sm text-slate-500 mt-1">{r.desc}</p>
                </div>
                <RatingBadge score={r.rating} size="md" />
              </div>
              <div class="mt-3 flex items-center gap-4 flex-wrap">
                <div>
                  <p class="text-xs text-slate-400">Top Pick</p>
                  <p class="text-sm font-semibold text-slate-800">{r.topPick} · <span class="font-[Barlow_Condensed] text-base">{r.price}</span></p>
                </div>
                <span class="ml-auto text-sm font-semibold text-green-600 group-hover:underline">Read review →</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>

</BaseLayout>
