---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Pickleball Paddle Reviews" description="Independent pickleball paddle reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing.">
  <div class="bg-orange-50 border-b border-orange-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb"><a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Pickleball</span></nav>
      <div class="flex items-center gap-3 mb-3"><span class="w-3 h-3 rounded-full bg-orange-500" aria-hidden="true"></span><span class="text-xs font-semibold text-orange-700 uppercase tracking-widest">Pickleball</span></div>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Pickleball Paddle Reviews</h1>
      <p class="mt-3 text-slate-500 text-base max-w-xl">Every paddle tested in real play. Honest ratings, full specs, and Indian pricing.</p>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center"><p class="text-slate-400 text-sm">Reviews coming soon.</p></div>
</BaseLayout>
