---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RatingBadge from "../../components/RatingBadge.astro";
import { collectionPageSchema, breadcrumbSchema, itemListSchema } from "../../utils/schema";

const reviews = [
  {
    title: "Best Pickleball Paddles Under 2500 in India 2026",
    desc: "Budget picks under ₹2500. Xtrieve USAPA T700 Carbon Fiber leads with its tournament-grade build at a beginner price.",
    href: "/reviews/best-pickleball-paddles-under-2500-india",
    topPick: "Xtrieve USAPA T700 Carbon Fiber",
    price: "₹2,380",
    rating: 9.4,
    level: "Beginner",
    lastUpdated: "Apr 2026",
    image: "https://m.media-amazon.com/images/I/315j8u1ZXiL._SL500_.jpg",
  },
  {
    title: "Best Pickleball Paddles Under 5000 in India 2026",
    desc: "Mid-range paddles under ₹5000. Voltik Alpha V1 delivers the best balance of power and control.",
    href: "/reviews/best-pickleball-paddles-under-5000-india",
    topPick: "Voltik Alpha V1",
    price: "₹3,699",
    rating: 9.4,
    level: "Beginner–Intermediate",
    lastUpdated: "Apr 2026",
    image: "https://m.media-amazon.com/images/I/315j8u1ZXiL._SL500_.jpg",
  },
  {
    title: "Best Pickleball Paddles Under 10000 in India 2026",
    desc: "Premium paddles under ₹10,000. YAIT Takumi GEN4 tops the list with its thermoformed edge and raw carbon face.",
    href: "/reviews/best-pickleball-paddles-under-10000-india",
    topPick: "YAIT Takumi GEN4",
    price: "₹7,979",
    rating: 9.5,
    level: "Intermediate",
    lastUpdated: "Apr 2026",
    image: "https://m.media-amazon.com/images/I/315j8u1ZXiL._SL500_.jpg",
  },
];

const jsonLd = { "@graph": [
  collectionPageSchema({ url: "/pickleball", name: "Pickleball Paddle Reviews", description: "Independent pickleball paddle reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing." }),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Pickleball", url: "/pickleball" }]),
  itemListSchema(reviews.map(r => ({ name: r.title, url: r.href }))),
] } as Record<string, unknown>;
---

<BaseLayout
  title="Pickleball Paddle Reviews"
  description="Independent pickleball paddle reviews for Indian players. In-depth specs, pros/cons, and expert ratings with real Indian pricing."
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <div class="bg-orange-50 border-b border-orange-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-xs text-slate-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-800">Home</a> › <span class="text-slate-700 font-medium">Pickleball</span>
      </nav>
      <div class="flex items-center gap-3 mb-3">
        <span class="w-3 h-3 rounded-full bg-orange-500" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-orange-700 uppercase tracking-widest">Pickleball</span>
      </div>
      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900">Pickleball Paddle Reviews</h1>
      <p class="mt-3 text-slate-500 text-base max-w-xl">Every paddle tested in real play. Honest ratings, full specs, and Indian pricing.</p>
    </div>
  </div>

  <!-- Review list -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-sm text-slate-400 mb-6">{reviews.length} review{reviews.length !== 1 ? "s" : ""} published</p>

    <div class="space-y-4">
      {reviews.map(r => (
        <article class="bg-white border border-slate-200 rounded-2xl p-5 flex flex-col sm:flex-row gap-5 hover:shadow-md transition-shadow">
          <div class="w-full sm:w-24 h-24 bg-slate-100 rounded-xl flex items-center justify-center flex-shrink-0 overflow-hidden">
            <img src={r.image} alt={r.topPick} class="w-full h-full object-contain p-2" loading="lazy" width="96" height="96" />
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div>
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <span class="text-xs font-semibold text-orange-700 bg-orange-100 px-2 py-0.5 rounded-full">{r.level}</span>
                  <span class="text-xs text-slate-400">Updated {r.lastUpdated}</span>
                </div>
                <h2 class="font-[Barlow_Condensed] text-xl font-bold text-slate-900">
                  <a href={r.href} class="hover:text-green-600 transition-colors">{r.title}</a>
                </h2>
                <p class="text-sm text-slate-500 mt-1">{r.desc}</p>
              </div>
              <RatingBadge score={r.rating} size="md" />
            </div>
            <div class="mt-3 flex items-center gap-4 flex-wrap">
              <div>
                <p class="text-xs text-slate-400">Top Pick</p>
                <p class="text-sm font-semibold text-slate-800">{r.topPick} · <span class="font-[Barlow_Condensed] text-base">{r.price}</span></p>
              </div>
              <a href={r.href} class="ml-auto text-sm font-semibold text-green-600 hover:underline">Read review →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

</BaseLayout>
