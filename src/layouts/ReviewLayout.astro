---
import BaseLayout from "./BaseLayout.astro";

interface TocItem {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  sport: "tennis" | "badminton" | "pickleball" | "squash" | "table-tennis";
  level?: string;
  lastUpdated: string;
  tocItems?: TocItem[];
  jsonLdNodes?: object[];
}

const { title, description, sport, level, lastUpdated, tocItems = [], jsonLdNodes } = Astro.props;

const jsonLd = jsonLdNodes ? { "@graph": jsonLdNodes } as Record<string, unknown> : null;

const sportDisplayNames: Record<string, string> = {
  tennis: "Tennis",
  badminton: "Badminton",
  pickleball: "Pickleball",
  squash: "Squash",
  "table-tennis": "Table Tennis",
};
const sportDisplayName = sportDisplayNames[sport] ?? sport;

const sportColors: Record<string, string> = {
  tennis: "bg-lime-100 text-lime-800 border-lime-200",
  badminton: "bg-cyan-100 text-cyan-800 border-cyan-200",
  pickleball: "bg-orange-100 text-orange-800 border-orange-200",
  squash: "bg-violet-100 text-violet-800 border-violet-200",
  "table-tennis": "bg-blue-100 text-blue-800 border-blue-200",
};
const sportClass = sportColors[sport] ?? "bg-slate-100 text-slate-700 border-slate-200";

const formattedDate = new Date(lastUpdated).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-xs text-slate-500">
          <li><a href="/" class="hover:text-slate-800 transition-colors">Home</a></li>
          <li aria-hidden="true">›</li>
          <li><a href={`/${sport}`} class="hover:text-slate-800 transition-colors">{sportDisplayName}</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-slate-700 font-medium" aria-current="page">{title}</li>
        </ol>
      </nav>

      <!-- Tags -->
      <div class="flex items-center gap-2 mb-4 flex-wrap">
        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full border ${sportClass}`}>{sportDisplayName}</span>
        {level && (
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full border bg-slate-100 text-slate-700 border-slate-200 capitalize">{level}</span>
        )}
      </div>

      <h1 class="font-[Barlow_Condensed] text-4xl sm:text-5xl font-bold text-slate-900 leading-tight max-w-3xl">
        {title}
      </h1>
      <p class="mt-4 text-slate-500 text-base sm:text-lg max-w-2xl leading-relaxed">{description}</p>

      <div class="mt-5 flex items-center gap-4 text-xs text-slate-400 flex-wrap">
        <span class="flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Last updated: <time datetime={lastUpdated}>{formattedDate}</time>
        </span>
        <span class="flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          ~10 min read
        </span>
      </div>

      <!-- Affiliate disclosure -->
      <div class="mt-5 inline-flex items-start gap-2 text-xs text-slate-500 bg-white border border-slate-200 rounded-lg px-3 py-2 max-w-lg">
        <svg class="flex-shrink-0 mt-0.5" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        We may earn a commission via Amazon.in or Flipkart affiliate links. Prices shown are indicative — check the retailer for current rates. This doesn't affect our reviews.
      </div>

    </div>
  </div>

  <!-- Page body: sidebar TOC + main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">

      <!-- Sticky TOC sidebar (desktop only) -->
      {tocItems.length > 0 && (
        <aside class="hidden lg:block w-56 flex-shrink-0">
          <div class="sticky top-24">
            <p class="font-[Barlow_Condensed] text-xs font-bold uppercase tracking-widest text-slate-400 mb-3">On This Page</p>
            <nav aria-label="Table of contents">
              <ul class="space-y-1">
                {tocItems.map(item => (
                  <li>
                    <a
                      href={`#${item.id}`}
                      class="toc-link block text-sm text-slate-500 hover:text-slate-900 py-1 border-l-2 border-transparent hover:border-green-500 pl-3 transition-colors"
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Main content -->
      <div class="flex-1 min-w-0 space-y-10">
        <slot />
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  // Active TOC link on scroll
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  const sections = Array.from(tocLinks).map(link => {
    const id = link.getAttribute("href")?.slice(1);
    return id ? document.getElementById(id) : null;
  }).filter(Boolean) as HTMLElement[];

  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove("active", "border-green-500", "text-green-600", "font-semibold"));
          const active = document.querySelector<HTMLAnchorElement>(`.toc-link[href="#${entry.target.id}"]`);
          if (active) active.classList.add("active", "border-green-500", "text-green-600", "font-semibold");
        }
      });
    },
    { rootMargin: "-80px 0px -60% 0px", threshold: 0 }
  );

  sections.forEach(s => observer.observe(s));
</script>
