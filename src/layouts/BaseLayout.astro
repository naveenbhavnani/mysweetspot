---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { organizationSchema, webSiteSchema, buildGraph } from "../utils/schema";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | null;
}

const {
  title,
  description = "India's independent racket reviews — tennis, badminton, pickleball, squash, and table tennis. In-depth specs, pros/cons, and expert ratings with Indian pricing.",
  ogImage,
  noindex = false,
  jsonLd = null,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);

// Merge base schema (Organization + WebSite) with any page-specific nodes
const baseNodes = [organizationSchema(), webSiteSchema()];
const pageNodes = jsonLd?.["@graph"] as object[] | undefined;
const finalJsonLd = buildGraph(...baseNodes, ...(pageNodes ?? []));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | MySweetSpot</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | MySweetSpot`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />

    <!-- Font preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NWKRRK9T0H" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NWKRRK9T0H');
    </script>
  </head>
  <body class="bg-white text-slate-900 min-h-dvh flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-green-600 text-white px-4 py-2 rounded-md z-[1000] font-medium text-sm">
      Skip to main content
    </a>

    <Header />

    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
